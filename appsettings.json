{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=Data/realestate.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Seed": {
    "RunOnStartup": false
  },
  "SqliteBackup": {
    "Enabled": true,
    "OncePerCalendarDay": true,
    "CheckIntervalHours": 1,
    "IntervalHours": 24,
    "RetentionCount": 10,
    "BackupRelativePath": "Data/Backups"
  },
  "Email": {
    "Enabled": false,
    "Host": "smtp.example.com",
    "Port": 587,
    "UseSsl": true,
    "UserName": "",
    "Password": "",
    "FromAddress": "noreply@example.com",
    "FromDisplayName": "Real Estate",
    "BccCompanyEmail": true,
    "ReminderDays": [ 30, 14, 7 ],
    "CheckIntervalHours": 24
  }
}
