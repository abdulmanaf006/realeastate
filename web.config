<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    IIS / ASP.NET Core Module hosting. Connection strings are not read from <connectionStrings> by default.
    For SQLite ZIP backups (SqliteZipBackupService), grant the app pool identity Modify on the application Data
    folder and Data/Backups (see SqliteBackup in appsettings.json).
    Override the database for this site by adding environment variables under <aspNetCore>, for example:
      <environmentVariables>
        <environmentVariable name="ConnectionStrings__DefaultConnection"
          value="Server=YOUR_SQL_HOST;Database=RealEstate;User Id=app;Password=***;TrustServerCertificate=True;MultipleActiveResultSets=true" />
      </environmentVariables>
    Or set environment variable DEFAULT_CONNECTION to the full connection string (see Program.cs).
  -->
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\RealEstate.Web.dll" stdoutLogEnabled="false" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
